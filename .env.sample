# echo-vault environment variables
# Copy this file to .env and fill in your values

# ---- Google Gemini (default provider) ----
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ---- OpenAI (optional, legacy provider) ----
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_ASSISTANT_ID=asst_your-assistant-id-here

# Zendesk / OptiSigns support URL
SUPPORT_BASE_URL=https://support.optisigns.com

# Output directory for scraped markdown files
OUTPUT_DIR=articles

# Hash store file (for delta detection)
HASH_STORE_FILE=article_hashes.json
UPLOAD_HASHES_FILE=upload_hashes.json
